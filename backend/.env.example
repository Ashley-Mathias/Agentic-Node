# backend/.env.example — copy to .env for local development (never commit secrets).
# OpenAI
OPENAI_API_KEY="sk-proj-your-key-here"
MODEL_NAME="gpt-4o-mini"
MODEL_TEMPERATURE=0.0

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/agentic_node"

# ChromaDB persistence directory
CHROMA_PERSIST_DIR="./chroma_data"

# Document upload directory
UPLOAD_DIR="./uploads"

# RAG chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Query safety
MAX_QUERY_ROWS=500
SQL_TIMEOUT_SECONDS=30

# LangSmith (optional — set to enable tracing for LangGraph runs)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY="your-langsmith-api-key"
# LANGCHAIN_PROJECT="agentic-node"
